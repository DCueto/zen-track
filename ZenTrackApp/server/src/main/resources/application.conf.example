ktor {
    deployment {
        port = 8080
        host = "0.0.0.0"
    }
    application {
        modules = [ me.dcueto.zentrackapp.ApplicationKt.module ]
    }
}

database {
    url = "jdbc:postgresql://localhost:5433/zentrack_db"
    driver = "org.postgresql.Driver"
    user = "your_user"
    password = "your_password"
    maxPoolSize = 10
}

jwt {
    secret = "your-secret-min-32-chars-change-in-production"
    issuer = "zentrack"
    audience = "zentrack-users"
    realm = "ZenTrack API"
    expirationMs = 86400000
}

google {
    clientId = "REPLACE_WITH_GOOGLE_CLIENT_ID"
    clientSecret = "REPLACE_WITH_GOOGLE_CLIENT_SECRET"
    redirectUri = "http://localhost:8080/api/auth/google/callback"
}
